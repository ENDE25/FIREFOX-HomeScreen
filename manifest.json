{
  "manifest_version": 2,
  "name": "HomeScreen",
  "version": "1.0",
  "description": "Custom new tab page with workspaces, search, and AI shortcuts.",
  "userDataCollected": false,
  "browser_specific_settings": {
    "gecko": {
      "id": "homescreen@ende_music",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "permissions": [
    "storage"
  ]
}
